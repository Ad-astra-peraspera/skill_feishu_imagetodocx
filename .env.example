FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_REDIRECT_HOST=127.0.0.1
FEISHU_REDIRECT_PORT=3333
FEISHU_REDIRECT_PATH=/feishu/callback
